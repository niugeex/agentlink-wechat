{
    "name": "@agentlink/wechat",
    "version": "0.1.0",
    "description": "AgentLink WeChat - WeChat iLink Bot SDK for AI Agents",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "files": [
        "dist"
    ],
    "engines": {
        "node": "\u003e=18"
    },
    "license": "MIT",
    "keywords": [
        "wechat",
        "bot",
        "ilink",
        "sdk"
    ],
    "type": "module",
    "scripts": {
        "build": "tsup src/index.ts --format esm,cjs --dts --clean",
        "test": "vitest run",
        "demo:openai-agent": "node examples/openai-doc-agent.ts"
    },
    "dependencies": {
        "@openai/agents": "^0.1.0",
        "openai": "^5.23.2",
        "zod": "^3.25.40"
    },
    "devDependencies": {
        "@types/node": "^24.6.0",
        "tsup": "^8.5.0",
        "typescript": "^5.9.2",
        "vitest": "^3.2.4"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/niugeex/agentlink-wechat.git"
    },
    "homepage": "https://github.com/niugeex/agentlink-wechat",
    "bugs": {
        "url": "https://github.com/niugeex/agentlink-wechat/issues"
    }
}